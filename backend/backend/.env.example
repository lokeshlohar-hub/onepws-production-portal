# Copy this file to .env for local development and fill in real values.
# On Render, set these as Environment Variables on the Web Service instead —
# DATABASE_URL is filled in automatically when you attach a Render Postgres
# instance to this service.

# Postgres connection string.
# Local example:  postgres://postgres:postgres@localhost:5432/onepws_dev
# Render fills this in for you automatically once the database is attached.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/onepws_dev

# Set to "false" only for local Postgres without SSL. Leave unset (or "true") on Render.
PGSSL=false

# Any long random string — used to sign login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

PORT=4000
